<?xml version="1.0"?>
<ruleset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         name="CommandFramework-Sonar-Lite"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0
             https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>PMD rules covering bug-prone patterns, code smells, and best practices.</description>

    <rule ref="category/java/bestpractices.xml">
        <exclude name="GuardLogStatement"/>
        <exclude name="JUnitTestContainsTooManyAsserts"/>
        <exclude name="JUnitAssertionsShouldIncludeMessage"/>
        <exclude name="JUnitTestsShouldIncludeAssert"/>
        <!--
          Flags Map<K,V> fields that already use the interface type and only fires because an
          initializer such as new LinkedHashMap<>() or new EnumMap<>(...) is used for insertion
          ordering or enum keying. The declared type is already the abstract interface, so every
          external consumer sees Map — the rule produces false positives here.
        -->
        <exclude name="LooseCoupling"/>
    </rule>

    <rule ref="category/java/errorprone.xml">
        <exclude name="AvoidFieldNameMatchingMethodName"/>
        <exclude name="BeanMembersShouldSerialize"/>
        <exclude name="DataflowAnomalyAnalysis"/>
        <exclude name="AvoidLiteralsInIfCondition"/>
        <exclude name="AvoidDuplicateLiterals"/>
        <!--
          Optional-style input-missing sentinel in CommandDispatcher.prepareInvocation uses a local
          String that is intentionally nulled to represent "no token" before the optional/required
          branch runs; rewriting to Optional<String> adds boxing with no readability gain.
        -->
        <exclude name="NullAssignment"/>
    </rule>

    <rule ref="category/java/multithreading.xml">
        <!--
          Every Map flagged by the rule is either (a) already a ConcurrentHashMap (DependencyContainer,
          enumResolverCache) or (b) a local/builder-phase map that is copied via Map.copyOf() before
          being handed to the dispatcher, so it is never shared across threads in mutable form.
        -->
        <exclude name="UseConcurrentHashMap"/>
        <!--
          CommandDispatcher.executePrepared intentionally uses Thread.ofVirtual() for @Async commands,
          and PaperActor.sendMessage checks Thread.currentThread().isVirtual() to hop back onto the
          region scheduler. Both are deliberate virtual-thread usage.
        -->
        <exclude name="DoNotUseThreads"/>
    </rule>

    <rule ref="category/java/performance.xml">
        <exclude name="AvoidInstantiatingObjectsInLoops"/>
    </rule>

    <rule ref="category/java/design.xml">
        <exclude name="LawOfDemeter"/>
        <exclude name="LoosePackageCoupling"/>
        <exclude name="ExcessiveImports"/>
        <exclude name="DataClass"/>
        <exclude name="TooManyMethods"/>
        <exclude name="TooManyFields"/>
        <exclude name="GodClass"/>
        <exclude name="CouplingBetweenObjects"/>
        <exclude name="CyclomaticComplexity"/>
        <exclude name="CognitiveComplexity"/>
        <exclude name="NPathComplexity"/>
        <exclude name="ExcessiveParameterList"/>
        <!--
          Top-level dispatch/suggest/executePrepared paths must not let runtime exceptions escape
          into the platform (Paper/Velocity) — the generic catch blocks log and return a safe
          CommandResult. DefaultArgumentResolvers.simple() must funnel any ThrowingFunction failure
          into ArgumentResolveException. VelocityActor.sendMessage guards against player-disconnect
          races. Narrow catches would defeat the intent.
        -->
        <exclude name="AvoidCatchingGenericException"/>
        <!--
          Number parsers (parseDouble/parseFloat) catch NumberFormatException to translate it into a
          typed ArgumentResolveException — idiomatic Java, not flow control abuse.
        -->
        <exclude name="ExceptionAsFlowControl"/>
        <!--
          DefaultArgumentResolvers.simple() re-throws ArgumentResolveException to bypass the generic
          wrap-as-resolve-failure branch that handles other exception types. Removing the rethrow
          would alter behaviour.
        -->
        <exclude name="AvoidRethrowingException"/>
        <!--
          ThrowingFunction is a package-private functional interface that intentionally accepts any
          checked exception from the caller-supplied mapper so parseInteger/parseLong/etc. can surface
          NumberFormatException. Narrowing the signature would require boilerplate wrappers at every
          call site with no safety gain.
        -->
        <exclude name="SignatureDeclareThrowsException"/>
    </rule>

    <rule ref="category/java/codestyle.xml">
        <exclude name="AtLeastOneConstructor"/>
        <exclude name="OnlyOneReturn"/>
        <exclude name="ShortVariable"/>
        <exclude name="LongVariable"/>
        <exclude name="CommentDefaultAccessModifier"/>
        <exclude name="UnnecessaryConstructor"/>
        <exclude name="LocalVariableCouldBeFinal"/>
        <exclude name="MethodArgumentCouldBeFinal"/>
        <exclude name="CallSuperInConstructor"/>
        <exclude name="ShortClassName"/>
        <exclude name="ShortMethodName"/>
        <exclude name="UseExplicitTypes"/>
        <exclude name="FieldNamingConventions"/>
    </rule>
</ruleset>
