<templateSet group="CommandFramework">
  <template name="cfcmd" value="@Command(name = &quot;$NAME$&quot;, description = &quot;$DESC$&quot;)&#10;public final class $CLASS$ {&#10;&#10;    @Execute&#10;    public void execute(@Sender $SENDER$ sender) {&#10;        $END$&#10;    }&#10;}"
            description="CommandFramework: @Command class with root executor"
            toReformat="true" toShortenFQNames="true">
    <variable name="NAME" expression="" defaultValue="&quot;hello&quot;" alwaysStopAt="true"/>
    <variable name="DESC" expression="" defaultValue="&quot;Describe me&quot;" alwaysStopAt="true"/>
    <variable name="CLASS" expression="fileNameWithoutExtension()" defaultValue="" alwaysStopAt="false"/>
    <variable name="SENDER" expression="" defaultValue="&quot;CommandActor&quot;" alwaysStopAt="true"/>
    <context>
      <option name="JAVA_DECLARATION" value="true"/>
    </context>
  </template>

  <template name="cfexec" value="@Execute(sub = &quot;$SUB$&quot;)&#10;@Description(&quot;$DESC$&quot;)&#10;public void $METHOD$(@Sender $SENDER$ sender$ARGS$) {&#10;    $END$&#10;}"
            description="CommandFramework: @Execute subcommand method"
            toReformat="true" toShortenFQNames="true">
    <variable name="SUB" expression="" defaultValue="&quot;sub&quot;" alwaysStopAt="true"/>
    <variable name="DESC" expression="" defaultValue="&quot;Describe me&quot;" alwaysStopAt="true"/>
    <variable name="METHOD" expression="" defaultValue="&quot;run&quot;" alwaysStopAt="true"/>
    <variable name="SENDER" expression="" defaultValue="&quot;CommandActor&quot;" alwaysStopAt="true"/>
    <variable name="ARGS" expression="" defaultValue="&quot;&quot;" alwaysStopAt="true"/>
    <context>
      <option name="JAVA_DECLARATION" value="true"/>
    </context>
  </template>

  <template name="cfcool" value="@Cooldown(value = $AMOUNT$, unit = java.util.concurrent.TimeUnit.$UNIT$, bypassPermission = &quot;$BYPASS$&quot;)"
            description="CommandFramework: @Cooldown annotation"
            toReformat="true" toShortenFQNames="true">
    <variable name="AMOUNT" expression="" defaultValue="30" alwaysStopAt="true"/>
    <variable name="UNIT" expression="enum(&quot;SECONDS&quot;, &quot;MINUTES&quot;, &quot;MILLISECONDS&quot;, &quot;HOURS&quot;)" defaultValue="&quot;SECONDS&quot;" alwaysStopAt="true"/>
    <variable name="BYPASS" expression="" defaultValue="&quot;myplugin.bypass&quot;" alwaysStopAt="true"/>
    <context>
      <option name="JAVA_DECLARATION" value="true"/>
    </context>
  </template>

  <template name="cfconfirm" value="@Confirm(expireSeconds = $SECONDS$, commandName = &quot;$CONFIRM$&quot;)"
            description="CommandFramework: @Confirm annotation"
            toReformat="true" toShortenFQNames="true">
    <variable name="SECONDS" expression="" defaultValue="10" alwaysStopAt="true"/>
    <variable name="CONFIRM" expression="" defaultValue="&quot;confirm&quot;" alwaysStopAt="true"/>
    <context>
      <option name="JAVA_DECLARATION" value="true"/>
    </context>
  </template>

  <template name="cfresolver" value="public final class $CLASS$ implements ArgumentResolver&lt;$TYPE$&gt; {&#10;&#10;    @Override&#10;    public Class&lt;$TYPE$&gt; type() {&#10;        return $TYPE$.class;&#10;    }&#10;&#10;    @Override&#10;    public $TYPE$ resolve(ArgumentResolutionContext context, String input) throws ArgumentResolveException {&#10;        $END$&#10;        throw new ArgumentResolveException(&quot;$ARG$&quot;, input, &quot;Invalid $ARG$&quot;);&#10;    }&#10;}"
            description="CommandFramework: custom ArgumentResolver skeleton"
            toReformat="true" toShortenFQNames="true">
    <variable name="CLASS" expression="fileNameWithoutExtension()" defaultValue="" alwaysStopAt="false"/>
    <variable name="TYPE" expression="" defaultValue="&quot;MyType&quot;" alwaysStopAt="true"/>
    <variable name="ARG" expression="" defaultValue="&quot;mytype&quot;" alwaysStopAt="true"/>
    <context>
      <option name="JAVA_DECLARATION" value="true"/>
    </context>
  </template>
</templateSet>
